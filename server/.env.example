# Neon.tech PostgreSQL Connection String
# Get this from your Neon.tech dashboard
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD_HERE@ep-your-endpoint.us-east-1.neon.tech/neondb?sslmode=require

# Server Configuration
HONEYPOT_PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Log settings
LOG_LEVEL=debug
